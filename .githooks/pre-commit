#!/bin/sh

set -eu

if [ "${SKIP_DOC_GUARD:-0}" = "1" ]; then
  exit 0
fi

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

has_code_impact=0
has_doc_update=0

for file in $STAGED_FILES; do
  case "$file" in
    README.md|AGENTS.md|CONTRIBUTING.md|docs/*|src/content/*)
      has_doc_update=1
      ;;
  esac

  case "$file" in
    src/*|public/*|package.json|pnpm-lock.yaml|next.config.ts|tailwind.config.*|postcss.config.*)
      has_code_impact=1
      ;;
  esac
done

if [ "$has_code_impact" -eq 1 ] && [ "$has_doc_update" -eq 0 ]; then
  echo "Documentation guard blocked this commit."
  echo ""
  echo "This commit changes implementation files but does not stage a documentation update."
  echo ""
  echo "Expected: include at least one relevant update in one of these areas:"
  echo "- README.md"
  echo "- CONTRIBUTING.md"
  echo "- docs/"
  echo ""
  echo "If this commit truly has no documentation impact, you can bypass once with:"
  echo "SKIP_DOC_GUARD=1 git commit ..."
  echo ""
  echo "You can also use: git commit --no-verify"
  exit 1
fi

exit 0
